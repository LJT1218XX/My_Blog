{
  "name": "shiguangji",
  "productName": "拾光集",
  "version": "1.0.0",
  "description": "Apple 风格个人博客桌面应用",
  "main": "src/main.js",
  "scripts": {
    "dev": "VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"vite --config src/renderer/vite.config.js\" \"electron-forge start\"",
    "build": "vite build --config src/renderer/vite.config.js",
    "start": "npm run build && electron-forge start",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "marked": "^18.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  }
}
